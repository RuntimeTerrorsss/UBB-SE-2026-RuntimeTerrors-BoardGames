<Page
    x:Class="BookingBoardgamesILoveBan.Src.PaymentHistory.View.PaymentHistoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BookingBoardgamesILoveBan.Src.PaymentHistory.View"
    xmlns:dto="using:BookingBoardgamesILoveBan.Src.PaymentHistory.DTO"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <Grid Padding="40,20,40,40" MaxWidth="1200" HorizontalAlignment="Center" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Payment History" FontSize="36" FontWeight="SemiBold" />
                    <TextBlock Text="View and track all your past transactions and receipts." FontSize="16" Foreground="Gray" Margin="0,4,0,0" />
                </StackPanel>

                <Button Content="← Back to Dashboard" Click="OnBackToDashboardClicked" Grid.Column="1" VerticalAlignment="Center" Padding="16,8"/>
            </Grid>

            <!-- Controls Card -->
            <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="20" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                        <TextBox Header="Search Product"
                                 Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Start typing..." 
                                 Width="240" />
                        <ComboBox Header="Date &amp; Sorting"
                                  ItemsSource="{x:Bind ViewModel.FilterOptions, Mode=OneTime}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{x:Bind ViewModel.SelectedFilterOption, Mode=TwoWay}"
                                  Width="200" />
                        <ComboBox Header="Method"
                                  ItemsSource="{x:Bind ViewModel.PaymentMethodOptions, Mode=OneTime}"
                                  SelectedItem="{x:Bind ViewModel.SelectedPaymentMethod, Mode=TwoWay}"
                                  Width="120" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                        <TextBlock Text="Total Spent" FontSize="12" Foreground="Gray" HorizontalAlignment="Right"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalAmount, Mode=OneWay}" 
                                   FontWeight="Bold" Foreground="ForestGreen" FontSize="28" 
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- List Header Row (Web Table style) -->
            <Grid Grid.Row="2" Padding="16,8,16,8" Margin="0,0,0,0" BorderBrush="LightGray" BorderThickness="0,0,0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Date / ID" Grid.Column="0" FontWeight="SemiBold" Foreground="DarkGray" FontSize="14"/>
                <TextBlock Text="Details" Grid.Column="1" FontWeight="SemiBold" Foreground="DarkGray" FontSize="14"/>
                <TextBlock Text="Amount" Grid.Column="2" FontWeight="SemiBold" Foreground="DarkGray" FontSize="14"/>
                <TextBlock Text="Method" Grid.Column="3" FontWeight="SemiBold" Foreground="DarkGray" FontSize="14"/>
                <TextBlock Text="Action" Grid.Column="4" FontWeight="SemiBold" Foreground="DarkGray" FontSize="14" HorizontalAlignment="Right"/>
            </Grid>

            <!-- User Story 2: Transaction List Display -->
            <ListView ItemsSource="{x:Bind ViewModel.Payments, Mode=OneWay}" 
                      Grid.Row="4" 
                      SelectionMode="None"
                      ShowsScrollingPlaceholders="True"
                      BorderBrush="Transparent" BorderThickness="0">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="dto:PaymentDto">
                        <!-- Individual Card Row -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                                CornerRadius="6" Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DateText}" FontSize="14" FontWeight="Medium"/>
                                    <TextBlock Text="{x:Bind Id}" FontSize="12" Foreground="Gray" Margin="0,2,0,0"/> 
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ProductName}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind ReceiverName}" FontSize="13" Foreground="Gray" Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Text="{x:Bind AmountText}" Grid.Column="2" VerticalAlignment="Center" FontWeight="Bold" FontSize="15"/>

                                <Border Grid.Column="3" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}" 
                                        CornerRadius="4" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind PaymentMethod}" FontSize="12" FontWeight="SemiBold"/>
                                </Border>

                                <Button Content="Receipt" Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center" 
                                        ToolTipService.ToolTip="Download receipt PDF" Tag="{x:Bind}" Click="OnReceiptButtonClicked"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Pagination Controls -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                <Button Content="Previous" Command="{x:Bind ViewModel.PreviousPageCommand}" Width="100"/>
                <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Medium">
                    <Run Text="Page "/>
                    <Run Text="{x:Bind ViewModel.CurrentPage, Mode=OneWay}"/>
                    <Run Text=" of "/>
                    <Run Text="{x:Bind ViewModel.TotalPages, Mode=OneWay}"/>
                </TextBlock>
                <Button Content="Next" Command="{x:Bind ViewModel.NextPageCommand}" Width="100"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
