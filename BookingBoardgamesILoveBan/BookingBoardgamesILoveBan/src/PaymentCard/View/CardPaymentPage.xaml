<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BookingBoardgamesILoveBan.Src.PaymentCard.View.CardPaymentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BookingBoardgamesILoveBan.Src.PaymentCard.View"
    xmlns:converters="using:BookingBoardgamesILoveBan.Src.PaymentCard.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

	<Grid Padding="40">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<!--  Title  -->
			<RowDefinition Height="Auto" />
			<!--  Order info  -->
			<RowDefinition Height="*" />
			<!--  Spacer  -->
			<RowDefinition Height="Auto" />
			<!--  Bottom actions  -->
		</Grid.RowDefinitions>

		<!--  Title  -->
		<TextBlock
			Grid.Row="0"
			Margin="0,0,0,24"
			FontSize="28"
			FontWeight="Bold"
			Text="Card Payment" />

        <!-- Order info panel -->
        <StackPanel Grid.Row="1" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Client:" FontWeight="Bold" Width="140"/>
                <TextBlock Text="{x:Bind ViewModel.ClientName, Mode=OneTime}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Game:" FontWeight="Bold" Width="140"/>
                <TextBlock Text="{x:Bind ViewModel.GameName, Mode=OneTime}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Rental Dates:" FontWeight="Bold" Width="140"/>
                <TextBlock Text="{x:Bind ViewModel.RequestDates, Mode=OneTime}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Owner:" FontWeight="Bold" Width="140"/>
                <TextBlock Text="{x:Bind ViewModel.OwnerName, Mode=OneTime}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Delivery Address:" FontWeight="Bold" Width="140"/>
                <TextBlock Text="{x:Bind ViewModel.DeliveryAddress, Mode=OneTime}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Delivery Date:" FontWeight="Bold" Width="140"/>
                <TextBlock Text="{x:Bind ViewModel.DeliveryDate, Mode=OneTime}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Price:" FontWeight="Bold" Width="140"/>
                <TextBlock Text="{x:Bind ViewModel.Price, Mode=OneTime}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Your Balance:" FontWeight="Bold" Width="140"/>
                <TextBlock Text="{x:Bind ViewModel.Balance, Mode=OneWay}"/>
            </StackPanel>
        </StackPanel>

		<!--  Payment panel — shown before payment  -->
		<StackPanel
			x:Name="PaymentPanel"
			Grid.Row="3"
			Spacing="16"
			Visibility="{x:Bind ViewModel.IsSuccess, Converter={StaticResource InverseBoolToVisibilityConverter}, Mode=OneWay}">

			<!--  Insufficient balance warning  -->
			<TextBlock
				Foreground="Red"
				Text="Insufficient balance. Please add funds to continue."
				Visibility="{x:Bind ViewModel.IsWarningVisible, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />

			<!--  Terms and conditions  -->
			<StackPanel Orientation="Horizontal" Spacing="8">
				<CheckBox IsChecked="{x:Bind ViewModel.TermsAccepted, Mode=TwoWay}" />
				<TextBlock VerticalAlignment="Center">
					<Run Text="I agree to the " />
					<Hyperlink Click="OnTermsLinkClick">Terms of Service</Hyperlink>
				</TextBlock>
			</StackPanel>

			<!--  Loading indicator  -->
			<ProgressRing
				Width="32"
				Height="32"
				HorizontalAlignment="Center"
				IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

			<!--  Action buttons  -->
			<Grid>
				<Button
					HorizontalAlignment="Left"
					Command="{x:Bind ViewModel.ExitCommand}"
					Content="Exit Payment" />
				<Button
					HorizontalAlignment="Right"
					Command="{x:Bind ViewModel.FinishPaymentCommand}"
					Content="Finish Payment"
					IsEnabled="{x:Bind ViewModel.IsPayButtonEnabled, Mode=OneWay}" />
			</Grid>
		</StackPanel>

		<!--  Success panel — shown after payment  -->
		<StackPanel
			x:Name="SuccessPanel"
			Grid.Row="3"
			Spacing="16"
			Visibility="{x:Bind ViewModel.IsSuccess, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
			<TextBlock
				FontSize="20"
				FontWeight="Bold"
				Text="Payment successful!" />
			<StackPanel Orientation="Horizontal" Spacing="8">
				<TextBlock FontWeight="Bold" Text="New balance:" />
				<TextBlock Text="{x:Bind ViewModel.Balance, Mode=OneWay}" />
			</StackPanel>
			<Button
				HorizontalAlignment="Left"
				Command="{x:Bind ViewModel.ExitCommand}"
				Content="Back to Chat" />
		</StackPanel>

	</Grid>
</Page>