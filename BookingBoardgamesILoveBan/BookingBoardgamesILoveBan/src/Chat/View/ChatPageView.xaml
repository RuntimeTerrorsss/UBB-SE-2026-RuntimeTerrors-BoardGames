<?xml version="1.0" encoding="utf-8" ?>
<Page
	x:Class="BookingBoardgamesILoveBan.src.Chat.View.ChatPageView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:BookingBoardgamesILoveBan.src.Chat.View"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
	mc:Ignorable="d">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="3*" />
		</Grid.ColumnDefinitions>

		<local:LeftPanelView Grid.Column="0" />

		<!--  Vertical divider between panels  -->
		<Border
			Grid.Column="0"
			Width="1"
			HorizontalAlignment="Right"
			Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

		<local:LeftPanelView x:Name="LeftPanel" Grid.Column="0" />
		<local:RightPanelView x:Name="RightPanel" Grid.Column="1" />
	</Grid>
</Page>
