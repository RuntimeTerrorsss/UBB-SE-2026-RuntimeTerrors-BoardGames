<?xml version="1.0" encoding="utf-8" ?>
<UserControl
	x:Class="BookingBoardgamesILoveBan.Src.Chat.View.ChatView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:BookingBoardgamesILoveBan.Src.Chat.View"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <!--  Banner  -->
            <RowDefinition Height="Auto" />
            <!--  Message scroll area  -->
            <RowDefinition Height="*" />
            <!--  Image preview (hidden until an image is pasted)  -->
            <RowDefinition Height="Auto" />
            <!--  Input bar  -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--
			Chat banner
		-->
        <Border
			Grid.Row="0"
			Padding="16,12"
			Background="{ThemeResource LayerFillColorDefaultBrush}"
			BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
			BorderThickness="0,0,0,1">
            <StackPanel
				VerticalAlignment="Center"
				Orientation="Horizontal"
				Spacing="12">
                <!--  Avatar placeholder  -->
                <PersonPicture
					x:Name="AvatarPicture"
					Width="40"
					Height="40" />
                <!--  Display name  -->
                <TextBlock
					x:Name="BannerDisplayName"
					VerticalAlignment="Center"
					FontSize="16"
					FontWeight="SemiBold"
					Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
            </StackPanel>
        </Border>

        <!--
			Scrollable message list
		-->
        <ScrollViewer
			x:Name="ScrollContainer"
			Grid.Row="1"
			Padding="16,12"
			VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="MessagesPanel" Spacing="4" />
        </ScrollViewer>

        <!--
			Staged image preview — visible only after a paste, hidden otherwise.
			The user reviews the image here before hitting Send.
		-->
        <Border
			x:Name="ImagePreviewPanel"
			Grid.Row="2"
			Padding="12,8"
			Background="{ThemeResource LayerFillColorDefaultBrush}"
			BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
			BorderThickness="0,1,0,0"
			Visibility="Collapsed">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <!--  Thumbnail  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  Label  -->
                    <ColumnDefinition Width="*" />
                    <!--  Discard button  -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Thumbnail of the pasted image  -->
                <Border
					Grid.Column="0"
					CornerRadius="6">
                    <Image
						x:Name="ImagePreview"
						MaxHeight="80"
						MaxWidth="120"
						Stretch="Uniform" />
                </Border>

                <!--  Label  -->
                <TextBlock
					Grid.Column="1"
					VerticalAlignment="Center"
					FontSize="13"
					Foreground="{ThemeResource TextFillColorSecondaryBrush}"
					Text="Image ready to send" />

                <!--  Discard the staged image  -->
                <Button
					x:Name="RemoveImageButton"
					Grid.Column="2"
					Width="32"
					Height="32"
					Padding="0"
					Background="Transparent"
					Click="RemoveImageButton_Click"
					ToolTipService.ToolTip="Remove image">
                    <FontIcon FontSize="14" Glyph="&#xE711;" />
                </Button>
            </Grid>
        </Border>

        <!--
			Input bar
		-->
        <Border
			Grid.Row="3"
			Padding="12,10"
			Background="{ThemeResource LayerFillColorDefaultBrush}"
			BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
			BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <!--  Attach image button  -->
                    <ColumnDefinition Width="Auto" />
                    <!--  Text input  -->
                    <ColumnDefinition Width="*" />
                    <!--  Send button  -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Attach image button  -->
                <Button
					x:Name="AttachImageButton"
					Grid.Column="0"
					Width="40"
					Height="40"
					Padding="0"
					Background="Transparent"
					ToolTipService.ToolTip="Attach image">
                    <FontIcon FontSize="18" Glyph="&#xE723;" />
                </Button>

                <!--  Text input: max 512 chars  -->
                <TextBox
					x:Name="MessageInput"
					Grid.Column="1"
					VerticalAlignment="Center"
					AcceptsReturn="False"
					CornerRadius="8"
					MaxLength="512"
					Paste="MessageInput_Paste"
					PlaceholderText="Type a message…"
					Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
					TextWrapping="Wrap" />
                <!--  TextChanged="MessageInput_TextChanged"  -->

                <!--  Send button  -->
                <Button
					x:Name="SendButton"
					Grid.Column="2"
					Width="40"
					Height="40"
					Padding="0"
					Click="SendButton_Click"
					Style="{StaticResource AccentButtonStyle}"
					ToolTipService.ToolTip="Send">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Enter" />
                    </Button.KeyboardAccelerators>
                    <FontIcon FontSize="16" Glyph="&#xE724;" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>