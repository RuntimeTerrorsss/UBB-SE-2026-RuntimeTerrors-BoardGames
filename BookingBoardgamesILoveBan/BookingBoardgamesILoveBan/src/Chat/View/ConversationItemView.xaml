<?xml version="1.0" encoding="utf-8" ?>
<UserControl
	x:Class="BookingBoardgamesILoveBan.src.Chat.View.ConversationItemView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:BookingBoardgamesILoveBan.src.Chat.View"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d">

	<Grid Padding="6,8" ColumnSpacing="10">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="44" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<PersonPicture
			x:Name="AvatarPicture"
			Width="44"
			Height="44" />

		<Grid Grid.Column="1" RowSpacing="2">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<TextBlock
				x:Name="DisplayNameText"
				Grid.Row="0"
				FontSize="14"
				FontWeight="SemiBold"
				Foreground="{ThemeResource TextFillColorPrimaryBrush}"
				MaxLines="1"
				Text="Alice Müller"
				TextTrimming="CharacterEllipsis" />

			<TextBlock
				x:Name="PreviewText"
				Grid.Row="1"
				FontSize="12"
				Foreground="{ThemeResource TextFillColorSecondaryBrush}"
				MaxLines="1"
				Text="Sure, I can drop it off tomorrow morning!"
				TextTrimming="CharacterEllipsis" />
		</Grid>

		<StackPanel
			Grid.Column="2"
			HorizontalAlignment="Right"
			VerticalAlignment="Stretch"
			Spacing="4">

			<TextBlock
				x:Name="TimestampText"
				HorizontalAlignment="Right"
				FontSize="11"
				Foreground="{ThemeResource TextFillColorTertiaryBrush}"
				Text="12:45" />

			<Border
				x:Name="UnreadBadge"
				Height="20"
				MinWidth="20"
				Padding="4,0"
				HorizontalAlignment="Right"
				Background="#C42B1C"
				CornerRadius="10"
				Visibility="{x:Bind GetBadgeVisibility(UnreadCount), Mode=OneWay}">
				<TextBlock
					x:Name="UnreadCountText"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					FontSize="11"
					FontWeight="SemiBold"
					Foreground="White"
					Text="3" />
			</Border>
		</StackPanel>
	</Grid>
</UserControl>